# Database — Prisma CLI requires an explicit user in the URL (unlike libpq defaults). Examples:
#   postgresql://YOUR_MAC_USERNAME@localhost:5432/upstream_literacy_dev
#   postgresql://postgres:password@localhost:5432/upstream_literacy_dev
DATABASE_URL="postgresql://postgres@localhost:5432/upstream_literacy_dev"
# Optional. Defaults to same host/user as DATABASE_URL with database "{main}_shadow" for Prisma Migrate.
# Create it with: pnpm run db:ensure (or make setup). Set explicitly if the shadow DB lives elsewhere.
# SHADOW_DATABASE_URL="postgresql://localhost:5432/upstream_literacy_dev_shadow"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
